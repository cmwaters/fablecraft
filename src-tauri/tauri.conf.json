{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fablecraft",
  "version": "0.1.4",
  "identifier": "com.fablecraft.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Fablecraft",
        "backgroundColor": [253, 246, 239],
        "width": 1440,
        "height": 920,
        "resizable": true,
        "center": true,
        "theme": "Light",
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDRTIyRDA3NzNBODlFQQpSV1RxaVRwMzBDTE9DN1JocXdqYlArM1VKUmkvRDNXcGN1aU9QQXg2Y3lnWXpuekR0QzFpa1JCSQo=",
      "endpoints": [
        "https://github.com/fablecraft-org/fablecraft/releases/latest/download/latest.json"
      ]
    }
  }
}
